# ─── EA SaaS Platform — Environment Variables ────────────────────────────────
# Copy this file to .env.local and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://ea_user:ea_password123@localhost:3306/ea_saas"
MYSQL_ROOT_PASSWORD="rootpassword123"
MYSQL_PASSWORD="ea_password123"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://:redis123@localhost:6379"
REDIS_PASSWORD="redis123"

# ─── Authentication ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-to-a-32-char-secret-key-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe (Billing) ───────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY="pk_test_REPLACE_WITH_YOUR_KEY"
STRIPE_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_KEY"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_WITH_YOUR_SECRET"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_REPLACE_WITH_YOUR_KEY"
EMAIL_FROM="noreply@yourdomain.com"

# ─── Application ─────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
API_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_EA_RPM=60
RATE_LIMIT_WEB_RPM=120

# ─── Heartbeat ──────────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL_SEC=60
HEARTBEAT_STALE_FACTOR=3

# ─── License ────────────────────────────────────────────────────────────────
LICENSE_CACHE_TTL_SEC=300

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_IP_ALLOWLIST="0.0.0.0/0"