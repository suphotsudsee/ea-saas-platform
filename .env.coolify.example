# Copy these values into the Coolify application environment.
# Replace credentials with the values shown in the Coolify MySQL and Redis resources.

DATABASE_URL=mysql://MYSQL_USER:MYSQL_PASSWORD@mysql-ea-saas:3306/MYSQL_DATABASE
REDIS_URL=redis://:REDIS_PASSWORD@redis-ea-saas:6379

NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=https://your-domain.example
APP_URL=https://your-domain.example
API_URL=https://your-domain.example

# Bootstrap admin account. Change these before production traffic.
ADMIN_EMAIL=admin@ea-saas.com
ADMIN_PASSWORD=Admin@2026!Secure

# Optional integrations
STRIPE_PUBLIC_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
RESEND_API_KEY=re_placeholder
EMAIL_FROM=noreply@your-domain.example
